# GoviHub Spices — Production Environment
# Copy this to .env.spices and fill in the values

APP_NAME=GoviHub Spices
APP_ENV=production
APP_DEBUG=false
APP_URL=https://spices.govihublk.com
ALLOWED_ORIGINS=https://spices.govihublk.com

# Database — generate DB_PASS with: openssl rand -hex 16
DB_PASS=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://govihub:${DB_PASS}@postgres-spices:5432/govihub_spices
DATABASE_URL_SYNC=postgresql://govihub:${DB_PASS}@postgres-spices:5432/govihub_spices

# Redis
REDIS_URL=redis://redis-spices:6379/0

# JWT — generate JWT_SECRET_KEY with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Google OAuth (not used in production spices — using beta auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLM (copy from beta)
OPENROUTER_API_KEY=COPY_FROM_BETA
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google AI (copy from beta — needed for Gemini crop diagnosis)
GOOGLE_AI_API_KEY=COPY_FROM_BETA

# External APIs
OPENWEATHER_API_KEY=

# Object Storage (Cloudflare R2)
R2_ACCOUNT_ID=COPY_FROM_BETA
R2_ACCESS_KEY_ID=COPY_FROM_BETA
R2_SECRET_ACCESS_KEY=COPY_FROM_BETA
R2_BUCKET_NAME=govihub-spices
R2_PUBLIC_URL=

# FCM / SMS (empty = graceful skip)
FCM_CREDENTIALS_PATH=
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (Resend) — used by admin automations (e.g. daily report)
# Reuse AiGNITE's Resend account; create a new scoped key named `govihub-spices-prod`
# at https://resend.com/api-keys (sending permission only). Domain `govihublk.com`
# must be verified at https://resend.com/domains for Path A from-address.
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@govihublk.com
RESEND_FROM_NAME=GoviHub Reports
ADMIN_REPORT_RECIPIENTS=govihub.ai@gmail.com

# MCP — generate with: openssl rand -hex 16
MCP_ADMIN_SECRET=CHANGE_ME
